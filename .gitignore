# ── Dependencies (root + any sub-project like /frontend) ──
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ───────────────────────────────────
.next/
out/

# ── Production / dist ─────────────────────────────────────
build/
dist/

# ── Testing / Coverage ────────────────────────────────────
coverage/

# ── Prisma generated client ───────────────────────────────
# (schema.prisma and migrations are source → DO commit them)
app/generated/
frontend/app/generated/
prisma/generated/
frontend/prisma/generated/

# ── TypeScript build info ─────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Secrets, Keys & Environment Variables ─────────────────
# Ignore all environment files and secret keys across root & subfolders
.env
.env*
*.env
*.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.pem
*.key
*.cert
*.crt
*.pfx
*.p12
*credentials*.json
client_secret*.json
service_account*.json

# ── Package lock files ────────────────────────────────────
# Keep package-lock.json committed (deterministic installs)
# But ignore yarn/pnpm lock if you are not using them
yarn.lock
pnpm-lock.yaml

# ── Vercel ────────────────────────────────────────────────
.vercel

# ── Debug / logs ──────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.pem

# ── Editor / IDE ──────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Python / Backend ──────────────────────────────────────
# Virtual environment
venv/
.venv/
env/
.env_venv/

# Python cache & compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
*.egg
*.egg-info/
dist/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy / pyright type checkers
.mypy_cache/
.pyright/
.dmypy.json
dmypy.json

# FastAPI / Uvicorn
*.pid

# ── Neon CLI & Cloud Services ──────────────────────────────
.neon
*.neon

# ── Local Caches & Temp Folders ───────────────────────────
.agents/
.turbo/
temp/
tmp/
backend/temp/*
!backend/temp/.gitkeep

# ── Database & Vector Store Files ─────────────────────────
*.sqlite
*.sqlite3
*.db
chroma_db/
.chroma/
chromadb/
